EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_DATA_MODE=mixed
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_KEY=
EXPO_PUBLIC_GIPHY_IOS_API_KEY=
EXPO_PUBLIC_GIPHY_ANDROID_API_KEY=
EXPO_PUBLIC_GIPHY_API_KEY=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_EXPO_PROJECT_ID=
EXPO_PUBLIC_SENTRY_ENABLED=false
EXPO_PUBLIC_SENTRY_DSN=

# Sentry capture is opt-in and temporarily off for development/staging/beta.
# Configure SENTRY_ORG and SENTRY_PROJECT in EAS when enabling release
# monitoring; keep SENTRY_AUTH_TOKEN only as an EAS secret for source maps.

# Supabase Edge Function secrets are private and must be configured in Supabase,
# never as EXPO_PUBLIC values:
# SUPABASE_SERVICE_ROLE_KEY=
