{
  "attachmentFolderPath": "assets",
  "newFileLocation": "folder",
  "newFileFolderPath": "docs",
  "useMarkdownLinks": true,
  "showUnsupportedFiles": false,
  "userIgnoreFilters": [
    "node_modules",
    "android",
    "ios",
    "coverage",
    "assets",
    ".expo",
    ".temp",
    "supabase/.temp",
    ".git",
