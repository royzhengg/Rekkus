{
  "name": "rekkus",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings=0",
    "lint:changed": "node scripts/lint-changed.js",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:diagnostics": "tsc --noEmit --extendedDiagnostics",
    "test": "jest",
    "test:unit": "jest tests/unit --runInBand",
    "test:search:quality": "jest tests/unit/lib/search/quality.test.ts tests/unit/lib/search/generated.test.ts --no-coverage",
    "test:coverage": "jest --coverage --runInBand",
    "test:type-safety": "node scripts/test-type-safety.js",
    "admin:import-places": "npx ts-node --project scripts/admin/tsconfig.json scripts/admin/osm/index.ts",
    "admin:import-places:dry": "npx ts-node --project scripts/admin/tsconfig.json scripts/admin/osm/index.ts --dry-run",
    "admin:embed-places": "npx ts-node --project scripts/admin/tsconfig.json scripts/admin/embed-places.ts",
    "admin:seed-embed-config": "npx ts-node --project scripts/admin/tsconfig.json scripts/admin/seed-embed-config.ts",
    "admin:backfill-hours": "npx ts-node --project scripts/admin/tsconfig.json scripts/admin/backfill-opening-hours.ts",
    "typegen:supabase:local": "supabase gen types typescript --local > types/database.ts",
    "check:supabase-types": "node scripts/check-supabase-types.js",
    "check:supabase-types:strict": "node scripts/check-supabase-types.js --strict",
    "check:platform": "npx expo config --type public && node scripts/check-platform.js",
    "check:docs": "node scripts/check-markdown-links.js",
    "check:dr": "node scripts/ops/check-disaster-recovery.js",
    "check:dead-code": "knip",
    "check:stale-flags": "node scripts/ops/check-stale-flags.js",
    "check:ops": "node scripts/ops/check-operations.js",
    "check:compliance": "node scripts/ops/check-compliance.js",
    "check:data-inventory": "node scripts/ops/check-data-inventory.js",
    "check:rls": "node scripts/ops/check-rls.js",
    "check:audit": "node scripts/ops/check-audit.js",
    "check:providers": "node scripts/ops/check-providers.js",
    "check:privacy": "node scripts/ops/check-privacy.js",
    "check:iso": "node scripts/ops/check-iso.js",
    "check:jobs": "node scripts/ops/check-job-monitors.js",
    "check:hig-acceptance": "node scripts/ops/check-hig-acceptance.js",
    "check:search": "node scripts/ops/check-search-governance.js && jest tests/unit/lib/services/googlePlacesLocationBias.test.ts tests/unit/lib/hooks/useRestaurantSearch.test.ts tests/unit/lib/search/quality.test.ts tests/unit/lib/search/generated.test.ts --no-coverage",
    "check:observability": "node scripts/ops/check-observability.js",
    "check:admin-platform": "node scripts/ops/check-admin-platform.js",
    "check:security-foundations": "node scripts/ops/check-security-foundations.js",
    "check:google-costs": "node scripts/ops/check-google-cost-reduction.js",
    "upgrade:maps": "node scripts/upgrade-maps.js",
    "check:deps": "npm audit --audit-level=high",
    "check:coverage": "node scripts/check-coverage.js",
    "check:ci-coverage": "node scripts/check-ci-coverage.js",
    "check:coordination": "node scripts/check-coordination.js",
    "check:circular-deps": "node scripts/check-circular-deps.js",
    "check:unsafe-any": "node scripts/check-unsafe-any.js",
    "check:architecture": "bash scripts/check-architecture.sh",
    "check:tokens": "bash scripts/check-tokens.sh",
    "check:darkmode": "bash scripts/check-darkmode.sh",
    "check:a11y": "bash scripts/check-a11y.sh",
    "check:automation": "bash scripts/check-automation.sh",
    "check:risk-guardrails": "node scripts/check-risk-guardrails.js",
    "check:ux-signals": "node scripts/check-ux-signals.js",
    "check:error-copy": "node scripts/check-error-copy.js",
    "check:performance": "bash scripts/check-performance.sh",
    "check:lessons": "node scripts/check-lessons.js",
    "check:tooling": "node scripts/check-tooling.js",
    "check:design-system": "node scripts/check-design-system.js",
    "check:design": "node scripts/run-parallel.js check:tokens check:darkmode check:a11y check:design-system",
    "check:hygiene": "node scripts/check-hygiene.js && node scripts/run-parallel.js check:backlog check:backlog-integrity check:coordination check:scripts check:coverage-chain test:type-safety typecheck lint check:tooling check:architecture check:performance check:unsafe-any check:supabase-types check:circular-deps check:design check:automation check:risk-guardrails check:ux-signals check:error-copy check:lessons check:docs check:ops check:search check:observability check:admin-platform check:security-foundations check:google-costs check:compliance check:data-inventory check:providers check:stale-flags check:hig-acceptance check:pipeline",
    "check:release": "npm run check:platform && npm run check:hygiene && node scripts/run-parallel.js check:dr check:privacy check:rls check:audit check:jobs check:iso check:deps",
    "validate": "npm run typecheck && npm run lint && npm run check:tokens && npm run check:darkmode",
    "validate:full": "npm run validate && npm run check:release",
    "ops:summary": "node scripts/ops/check-operations.js --summary",
    "ops:report": "node scripts/ops/check-operations.js --summary --write",
    "ops:pr": "node scripts/ops/pr-summary.js",
    "release:smoke": "node scripts/ops/release-smoke-checklist.js",
    "run-parallel": "node scripts/run-parallel.js",
    "check:coverage-chain": "npm run test:unit && npm run check:coverage && npm run check:ci-coverage",
    "check:pipeline": "node scripts/check-pipeline.js",
    "check:scripts": "node scripts/check-scripts.js",
    "check:backlog": "node scripts/check-backlog.js",
    "check:backlog-integrity": "node scripts/ops/check-backlog-integrity.js",
    "add-completed-item": "node scripts/ops/add-completed-item.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "^8.12.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.105.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-compressor": "^1.18.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-native-community/cli": "^20.1.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --max-warnings=0 --no-warn-ignored",
    "*.{json,md}": "prettier --check"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20 <23"
  }
}
