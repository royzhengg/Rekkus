{
  "name": "rekkus",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check:platform": "npx expo config --type public && node scripts/check-platform.js",
    "check:docs": "node scripts/check-markdown-links.js",
    "check:dr": "node scripts/ops/check-disaster-recovery.js",
    "check:dead-code": "node scripts/ops/check-dead-code.js",
    "check:ops": "node scripts/ops/check-operations.js",
    "check:compliance": "node scripts/ops/check-compliance.js",
    "check:data-inventory": "node scripts/ops/check-data-inventory.js",
    "check:rls": "node scripts/ops/check-rls.js",
    "check:audit": "node scripts/ops/check-audit.js",
    "check:providers": "node scripts/ops/check-providers.js",
    "check:privacy": "node scripts/ops/check-privacy.js",
    "check:iso": "node scripts/ops/check-iso.js",
    "check:jobs": "node scripts/ops/check-job-monitors.js",
    "check:search": "node scripts/ops/check-search-governance.js",
    "check:observability": "node scripts/ops/check-observability.js",
    "check:admin-platform": "node scripts/ops/check-admin-platform.js",
    "check:security-foundations": "node scripts/ops/check-security-foundations.js",
    "check:google-costs": "node scripts/ops/check-google-cost-reduction.js",
    "upgrade:maps": "node scripts/upgrade-maps.js",
    "check:deps": "npm audit --audit-level=moderate",
    "check:ci-coverage": "node scripts/check-ci-coverage.js",
    "check:architecture": "bash scripts/check-architecture.sh",
    "check:tokens": "bash scripts/check-tokens.sh",
    "check:darkmode": "bash scripts/check-darkmode.sh",
    "check:a11y": "bash scripts/check-a11y.sh",
    "check:design": "npm run check:tokens && npm run check:darkmode && npm run check:a11y && node scripts/check-design-system.js",
    "check:hygiene": "node scripts/check-hygiene.js && npm run check:architecture && npm run check:design && npm run check:ci-coverage && npm run check:docs && npm run check:ops && npm run check:search && npm run check:observability && npm run check:admin-platform && npm run check:security-foundations && npm run check:google-costs && npm run check:compliance && npm run check:data-inventory && npm run check:providers",
    "check:release": "npm run check:platform && npm run check:hygiene && npm run check:dr && npm run check:privacy && npm run check:rls && npm run check:audit && npm run check:jobs && npm run check:iso && npm run check:deps && npm run typecheck",
    "ops:summary": "node scripts/ops/check-operations.js --summary",
    "ops:report": "node scripts/ops/check-operations.js --summary --write",
    "ops:pr": "node scripts/ops/pr-summary.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.105.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "prettier": "^3.8.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-compressor": "^1.18.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20 <23"
  }
}
